# ── CSRF Protection ─────────────────────────────────────────────────────────
# Your production domain (no trailing slash). Required for origin/referer check.
ALLOWED_ORIGIN=https://yourdomain.com

# ── Contact Form Email Delivery (optional) ──────────────────────────────────
# If SMTP_HOST is not set, form submissions are logged to Vercel function logs only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO=inbox@yourdomain.com
